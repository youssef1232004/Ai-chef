# Root .gitignore for the project

# Node and package managers
node_modules/
npm-debug.log*
yarn-error.log*
pnpm-debug.log*

# Build outputs
dist/
build/
dist-ssr/

# Vite / bundler caches
.vite/
.parcel-cache/
.cache/

# Environment files
.env
.env.local
.env.*.local

# Logs
logs/
*.log

# Test coverage
coverage/
.nyc_output/

# OS and editor files
.DS_Store
Thumbs.db
.vscode/
.idea/

# Misc
.pnp.cjs
.pnp.js
.turbo/
/.expo/
